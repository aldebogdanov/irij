;; Run all Irij stdlib test suites.
;; Usage: irij tests/run-all.irj

use std.test :open
use std.math :open
use std.text {chars words lines unwords unlines blank? contains-substr? pad-left pad-right repeat}
use std.collection :open
use std.func {flip compose pipe apply-to on juxt complement constantly}
use std.convert {to-int to-float digits}

;; ── std.math ────────────────────────────────────────

println "=== std.math ==="

m1 := test "sqrt" (-> assert-eq 4.0 (sqrt 16))
m2 := test "floor" (-> assert-eq 3.0 (floor 3.7))
m3 := test "ceil" (-> assert-eq 4.0 (ceil 3.2))
m4 := test "pow" (-> assert-eq 8.0 (pow 2 3))
m5 := test "abs" (-> assert-eq 5 (abs (0 - 5)))
m6 := test "clamp" (-> assert-eq 5 (clamp 0 10 5))
m7 := test "even?" (-> assert-true (even? 4))
m8 := test "odd?" (-> assert-true (odd? 3))
m9 := test "gcd" (-> assert-eq 6 (gcd 12 18))
m10 := test "square" (-> assert-eq 25 (square 5))

;; ── std.text ────────────────────────────────────────

println ""
println "=== std.text ==="

t1 := test "chars" (-> assert-eq #["h" "i"] (chars "hi"))
t2 := test "words" (-> assert-eq #["a" "b"] (words "a b"))
t3 := test "lines" (-> assert-eq #["a" "b"] (lines "a\nb"))
t4 := test "unwords" (-> assert-eq "a b" (unwords #["a" "b"]))
t5 := test "unlines" (-> assert-eq "a\nb" (unlines #["a" "b"]))
t6 := test "blank?" (-> assert-true (blank? "  "))
t7 := test "contains-substr?" (-> assert-true (contains-substr? "hello" "ell"))
t8 := test "pad-left" (-> assert-eq "00042" (pad-left 5 "0" "42"))
t9 := test "repeat" (-> assert-eq "ababab" (repeat 3 "ab"))

;; ── std.collection ──────────────────────────────────

println ""
println "=== std.collection ==="

c1 := test "zip" (-> assert-eq #[#(1 :a) #(2 :b)] (zip #[1 2] #[:a :b]))
c2 := test "enumerate" (-> assert-eq #[#(0 :a) #(1 :b)] (enumerate #[:a :b]))
c3 := test "flatten" (-> assert-eq #[1 2 3 4] (flatten #[#[1 2] #[3 4]]))
c4 := test "distinct" (-> assert-eq #[1 2 3] (distinct #[1 2 1 3]))
c5 := test "sum" (-> assert-eq 10 (sum #[1 2 3 4]))
c6 := test "all?" (-> assert-true (all? (x -> x > 0) #[1 2 3]))
c7 := test "any?" (-> assert-true (any? (x -> x > 5) #[1 6]))
c8 := test "take-while" (-> assert-eq #[1 2] (take-while (x -> x < 3) #[1 2 5 6]))
c9 := test "flat-map" (-> assert-eq #[1 1 2 2] (flat-map (x -> #[x x]) #[1 2]))
c10 := test "sort-by" (-> assert-eq #["a" "bb" "ccc"] (sort-by length #["ccc" "a" "bb"]))

;; ── std.func ────────────────────────────────────────

println ""
println "=== std.func ==="

f1 := test "flip" (-> assert-eq (0 - 3) (flip (-) 5 2))
f2 := test "compose" (-> assert-eq 7 (compose (x -> x + 1) (x -> x * 2) 3))
f3 := test "pipe" (-> assert-eq 7 (pipe (x -> x * 2) (x -> x + 1) 3))
f4 := test "constantly" (-> assert-eq 42 (constantly 42 "anything"))

;; ── std.convert ─────────────────────────────────────

println ""
println "=== std.convert ==="

v1 := test "to-int" (-> assert-eq 42 (to-int "42"))
v2 := test "to-float" (-> assert-eq 3.14 (to-float "3.14"))

;; ── Summary ─────────────────────────────────────────

println ""
println "=== TOTAL ==="
summarize #[m1 m2 m3 m4 m5 m6 m7 m8 m9 m10 t1 t2 t3 t4 t5 t6 t7 t8 t9 c1 c2 c3 c4 c5 c6 c7 c8 c9 c10 f1 f2 f3 f4 v1 v2]
