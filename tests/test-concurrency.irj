use std.test :open
use std.text {contains-substr?}

;; ── scope + fork + await ───────────────────────────────

result1 :! 0
scope s
  f := s.fork (-> 10 + 20)
  result1 <- await f

r1 := test "scope fork await" (-> assert-eq 30 result1)

a :! 0
b :! 0
scope s
  f1 := s.fork (-> 3 * 7)
  f2 := s.fork (-> 5 + 5)
  a <- await f1
  b <- await f2

r2 := test "scope multiple forks" (-> assert-eq 31 (a + b))

;; ── par combinator ─────────────────────────────────────

r3 := test "par combines results" (-> assert-eq 300 (par (+) (-> 100) (-> 200)))
r4 := test "par with sleep" (-> assert-eq 300 (par (+) (-> sleep 10; 100) (-> sleep 10; 200)))

;; ── race combinator ────────────────────────────────────

r5 := test "race returns first" (-> assert-eq "fast" (race (-> sleep 500; "slow") (-> "fast")))

;; ── timeout ────────────────────────────────────────────

r6 := test "timeout completes" (-> assert-eq "done" (timeout 1000 (-> sleep 10; "done")))

fn check-timeout-expires
  _ =>
    r := try (-> timeout 10 (-> sleep 5000; "never"))
    match r
      (Err msg) => contains-substr? msg "timeout"
      _ => false

r7 := test "timeout expires" (-> assert-true (check-timeout-expires ()))

;; ── scope.race ─────────────────────────────────────────

race-result :! ""
scope.race s
  s.fork (-> sleep 500; "slow")
  s.fork (-> race-result <- "fast"; "fast")

r8 := test "scope.race first wins" (-> assert-eq "fast" race-result)

;; ── scope.supervised ───────────────────────────────────

supervised-ok :! false
scope.supervised s
  s.fork (-> error "fail")
  s.fork (-> sleep 50; supervised-ok <- true)

r9 := test "scope.supervised survives failure" (-> assert-true supervised-ok)

;; ── scope waits for all fibers ─────────────────────────

waited :! false
scope s
  s.fork (-> sleep 30; waited <- true)

r10 := test "scope waits for fibers" (-> assert-true waited)

summarize #[r1 r2 r3 r4 r5 r6 r7 r8 r9 r10]
