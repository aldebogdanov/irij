use std.test :open

;; ── Static methods (java.lang auto-imported) ─────────

r1 := test "Math/abs preserves int" (-> assert-eq 7 (Math/abs (-7)))
r2 := test "Math/max picks long overload" (-> assert-eq 5 (Math/max 3 5))
r3 := test "Math/pow returns double" (-> assert-eq 8.0 (Math/pow 2.0 3.0))
r4 := test "System/getenv returns Str" (-> assert-eq true (not (System/getenv "HOME" == "")))

;; ── Fully-qualified classes ──────────────────────────

uuid-str := (java.util.UUID/randomUUID ()).toString ()
r5 := test "UUID toString length is 36" (-> assert-eq 36 (length uuid-str))
r6 := test "Long/parseLong" (-> assert-eq 42 (java.lang.Long/parseLong "42"))

;; ── Instance methods via dot-access ───────────────────

r7  := test "String.toUpperCase" (-> assert-eq "HELLO" ("hello".toUpperCase ()))
r8  := test "String.length"      (-> assert-eq 5       ("hello".length ()))
r9  := test "String.trim"        (-> assert-eq "x"     ("   x   ".trim ()))
r10 := test "String.startsWith"  (-> assert-eq true    ("hello".startsWith "he"))

;; ── Constructors via Class/new ───────────────────────

sb := java.lang.StringBuilder/new ()
ra := sb.append "a"
rb := sb.append "b"
rc := sb.append "c"
r11 := test "StringBuilder chain" (-> assert-eq "abc" (sb.toString ()))

rnd := java.util.Random/new 42
rnd2 := java.util.Random/new 42
r12 := test "Random seeded is deterministic" (-> assert-eq (rnd.nextInt 1000) (rnd2.nextInt 1000))

;; ── Coercion edge cases ───────────────────────────────

r13 := test "int arg coerced from Long"  (-> assert-eq 3 (Math/floorDiv 10 3))
r14 := test "static field read Math/PI"  (-> assert-eq true ((Math/PI) > 3.0))

summarize #[r1 r2 r3 r4 r5 r6 r7 r8 r9 r10 r11 r12 r13 r14]
