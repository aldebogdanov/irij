use std.test :open
use std.db :open

;; ── std.db effect surface ────────────────────────────────────────
;;
;; All Db operations are effect ops; the JDBC bridge lives behind
;; the `db-jdbc` cap inside std/db.irj. No more raw-db-* names.
;;
;; Each test body keeps the with-block flat (open / helper-fn /
;; close) and pushes the actual logic into named helper fns. The
;; SM classifier prefers many short segments to one big inline
;; expression with lambdas-containing-performs.

;; ── open / close ─────────────────────────────────────────────────

fn open-close-body ::: Db
  =>
  conn := db-open ":memory:"
  result := type-of conn
  db-close conn
  result

fn test-open-close ::: Db
  =>
  with default-db
    open-close-body ()

test "db-open and db-close" (-> assert-eq "DbConn" (test-open-close ()))

;; ── round-trip ────────────────────────────────────────────────────

fn round-trip-body ::: Db
  =>
  conn := db-open ":memory:"
  db-exec conn "CREATE TABLE t (id INTEGER PRIMARY KEY, name TEXT)" #[]
  db-exec conn "INSERT INTO t (name) VALUES (?)" #["Alice"]
  db-exec conn "INSERT INTO t (name) VALUES (?)" #["Bob"]
  rows := db-query conn "SELECT * FROM t ORDER BY id" #[]
  assert-eq 2 (length rows)
  assert-eq "Alice" (head rows).name
  assert-eq "Bob" (head (tail rows)).name
  db-close conn

fn test-round-trip ::: Db
  =>
  with default-db
    round-trip-body ()

test "db-exec + db-query round-trip" (-> test-round-trip ())

;; ── affected count ───────────────────────────────────────────────

fn affected-body ::: Db
  =>
  conn := db-open ":memory:"
  db-exec conn "CREATE TABLE t (id INTEGER PRIMARY KEY, v TEXT)" #[]
  db-exec conn "INSERT INTO t (v) VALUES (?)" #["a"]
  db-exec conn "INSERT INTO t (v) VALUES (?)" #["b"]
  db-exec conn "INSERT INTO t (v) VALUES (?)" #["c"]
  n := db-exec conn "DELETE FROM t WHERE id > ?" #[1]
  db-close conn
  n

fn test-affected ::: Db
  =>
  with default-db
    affected-body ()

test "db-exec returns affected count" (-> assert-eq 2 (test-affected ()))

;; ── type coercion ────────────────────────────────────────────────

fn types-body ::: Db
  =>
  conn := db-open ":memory:"
  db-exec conn "CREATE TABLE t (i INTEGER, r REAL, s TEXT)" #[]
  db-exec conn "INSERT INTO t VALUES (?, ?, ?)" #[42 3.14 "hello"]
  rows := db-query conn "SELECT * FROM t" #[]
  row := head rows
  assert-eq "Int" (type-of row.i)
  assert-eq "Float" (type-of row.r)
  assert-eq "Str" (type-of row.s)
  assert-eq 42 row.i
  db-close conn

fn test-types ::: Db
  =>
  with default-db
    types-body ()

test "query returns correct types" (-> test-types ())

;; ── null round-trip ──────────────────────────────────────────────

fn null-body ::: Db
  =>
  conn := db-open ":memory:"
  db-exec conn "CREATE TABLE t (a TEXT, b TEXT)" #[]
  db-exec conn "INSERT INTO t VALUES (?, ?)" #["x" ()]
  rows := db-query conn "SELECT * FROM t" #[]
  row := head rows
  assert-eq "x" row.a
  assert-eq "Unit" (type-of row.b)
  db-close conn

fn test-null ::: Db
  =>
  with default-db
    null-body ()

test "query with null values" (-> test-null ())

;; ── transactions ─────────────────────────────────────────────────

fn tx-commit-insert ::: Db
  => conn
  db-exec conn "INSERT INTO t (v) VALUES (?)" #["inside-tx"]

fn tx-commit-body ::: Db
  =>
  conn := db-open ":memory:"
  db-exec conn "CREATE TABLE t (v TEXT)" #[]
  db-transaction conn (-> tx-commit-insert conn)
  rows := db-query conn "SELECT * FROM t" #[]
  assert-eq 1 (length rows)
  assert-eq "inside-tx" (head rows).v
  db-close conn

fn test-tx-commit ::: Db
  =>
  with default-db
    tx-commit-body ()

test "db-transaction commits" (-> test-tx-commit ())

fn insert-and-fail ::: Db
  => conn
  db-exec conn "INSERT INTO t (v) VALUES (?)" #["should-rollback"]
  error "boom"

fn tx-rollback-attempt ::: Db
  => conn
  db-transaction conn (-> insert-and-fail conn)

fn tx-rollback-body ::: Db
  =>
  conn := db-open ":memory:"
  db-exec conn "CREATE TABLE t (v TEXT)" #[]
  try (-> tx-rollback-attempt conn)
  rows := db-query conn "SELECT * FROM t" #[]
  assert-eq 0 (length rows)
  db-close conn

fn test-tx-rollback ::: Db
  =>
  with default-db
    tx-rollback-body ()

test "db-transaction rolls back on error" (-> test-tx-rollback ())

;; ── Mock handler ─────────────────────────────────────────────────
;;
;; Every effect op needs a clause now (including db-open / db-close).
;; The mock returns a sentinel "conn" since it never touches the cap.

handler mock-db :: Db
  db-open _ => resume "fake-conn"
  db-close _ => resume ()
  db-query conn sql params =>
    resume #[{name= "mock-alice" age= 99}]
  db-exec conn sql params =>
    resume 0
  db-transaction conn thunk =>
    resume (thunk ())

fn fetch-users ::: Db
  (conn -> db-query conn "SELECT * FROM users" #[])

fn mock-body ::: Db
  =>
  conn := db-open "ignored"
  users := fetch-users conn
  db-close conn
  assert-eq 1 (length users)
  assert-eq "mock-alice" (head users).name
  assert-eq 99 (head users).age

fn test-mock ::: Db
  =>
  with mock-db
    mock-body ()

test "mock Db handler" (-> test-mock ())
