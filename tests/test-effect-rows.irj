;; test-effect-rows.irj — Effect row declarations and checking (Phase 7a)
;;
;; Positive-only runtime tests. Negative cases (intentionally bad code
;; that the compiler must reject) are encoded as JUnit lint tests in
;; src/test/java/dev/irij/compiler/EffectRowLintTest.java — they would
;; trip the static checker before this file could even compile.

use std.test :open

;; ── 1. Shorthand effect annotation ::: Console ──────────────────────

fn greet ::: Console
  (name -> println ("Hello, " ++ name))

fn run-greet ::: Console
  =>
  greet "world"
  true

r1 := test "fn with ::: Console can call println" (-> assert-true (run-greet ()))

;; ── 2. Pure fn (unannotated) computes correctly ─────────────────────

fn add
  (a b -> a + b)

r2 := test "pure fn computes correctly" (-> assert-eq (add 3 4) 7)

;; ── 3. User-defined effect checked ──────────────────────────────────

effect MyLog
  log-it :: Str -> ()

handler my-logger :: MyLog ::: Console
  log-it msg => resume (println msg)

fn do-stuff ::: MyLog
  (x -> log-it x)

fn run-user-effect ::: Console
  =>
  with my-logger
    do-stuff "test-msg"
  true

r3 := test "fn with ::: MyLog can call MyLog ops" (-> assert-true (run-user-effect ()))

;; ── 4. Multiple effects in row ──────────────────────────────────────

effect Beep
  beep :: () -> ()

handler beeper :: Beep
  beep () => resume ()

fn multi ::: MyLog Beep
  =>
  log-it "beeping"
  beep ()

fn run-multi ::: Console
  =>
  with my-logger >> beeper
    multi ()
  true

r4 := test "fn with multiple effects in row" (-> assert-true (run-multi ()))

;; ── 5. Effect via type annotation syntax ────────────────────────────

fn typed-greet :: Str () ::: Console
  (name -> println ("Typed: " ++ name))

fn run-typed ::: Console
  =>
  typed-greet "world"
  true

r5 := test "effect row from type annotation works" (-> assert-true (run-typed ()))

;; ── 6. Imperative fn with effect row ────────────────────────────────

fn imp-greet ::: Console
  => name
  println ("Imp: " ++ name)

fn run-imp ::: Console
  =>
  imp-greet "test"
  true

r6 := test "imperative fn with effect row" (-> assert-true (run-imp ()))

;; ── 7. Match fn with effect row ─────────────────────────────────────

fn describe ::: Console
  0 => println "zero"
  n => println ("num: " ++ to-str n)

fn run-describe ::: Console
  =>
  describe 0
  describe 42
  true

r7 := test "match fn with effect row" (-> assert-true (run-describe ()))

;; ── 8. Partial application preserves effect row ─────────────────────

fn greet2 ::: Console
  (prefix name -> println (prefix ++ name))

fn run-partial ::: Console
  =>
  hi := greet2 "Hi, "
  hi "Irij"
  true

r8 := test "partial app preserves effect row" (-> assert-true (run-partial ()))

;; ── 9. Contracts + effects ──────────────────────────────────────────

fn safe-print ::: Console
  pre (x -> x /= "")
  (x -> println x)

fn check-contract-effect ::: Console
  =>
  safe-print "works"
  r := try (-> safe-print "")
  match r
    (Err _) => true
    _ => false

r9 := test "contracted fn with effect row" (-> assert-true (check-contract-effect ()))

;; ── 10. Handler with effect annotation allows declared effects ──────

handler annotated-logger :: MyLog ::: Console
  log-it msg => resume (println msg)

fn run-annotated-handler ::: Console
  =>
  with annotated-logger
    do-stuff "test"
  true

r10 := test "handler with ::: Console allows println in clause" (-> assert-true (run-annotated-handler ()))

;; ── Summarize ───────────────────────────────────────────────────────

summarize #[r1 r2 r3 r4 r5 r6 r7 r8 r9 r10]
