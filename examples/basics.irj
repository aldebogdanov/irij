;; ── Bindings ──────────────────────────────────────
x := 42
name := "hello"
pi := 3.14

;; ── Mutable binding ──────────────────────────────
counter :! 0

;; ── Function (inline lambda body) ────────────────
fn add :: Int -> Int -> Int
  (x y -> x + y)

;; ── Function (pattern-matching clauses) ──────────
fn fib :: Int -> Int
  0 => 0
  1 => 1
  n => fib (n - 1) + fib (n - 2)

;; ── Pipeline ─────────────────────────────────────
result := #[1 2 3] |> @ double |> ? even? |> /+
