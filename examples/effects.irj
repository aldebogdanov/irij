;; ── Effect declaration ────────────────────────────
effect Console
  print :: Str -> ()
  read-line :: () -> Str

;; ── Handler ──────────────────────────────────────
handler console-to-stdout :: Console
  print msg => io.stdout.write msg
  read-line () => io.stdin.read-line ()

;; ── Effectful function ───────────────────────────
fn greet :: Str -[Console]-> ()
  name := read-line ()
  print "Hello, ${name}!"
