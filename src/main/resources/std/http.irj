mod std.http

;; HTTP client effect module.
;;
;; Usage:
;;   use std.http :open
;;
;;   fn fetch-users ::: Http
;;     => base-url
;;     resp := http-get (base-url ++ "/users")
;;     json-parse resp.body
;;
;;   ;; Real HTTP:
;;   with default-http
;;     fetch-users "https://api.example.com"
;;
;;   ;; Mock in tests:
;;   handler mock-http :: Http
;;     http-get url => resume {status= 200 body= "[]" headers= {}}
;;     http-post url body headers => resume {status= 201 body= "" headers= {}}
;;
;;   with mock-http
;;     fetch-users "http://test"

pub effect Http
  http-get :: Str Map
  http-post :: Str Str Map Map
  http-put :: Str Str Map Map
  http-delete :: Str Map
  http-request :: Map Map

;; Capability binding. The `http-client` name resolves only inside
;; Http-handler clauses.
cap http-client :: Http = "dev.irij.runtime.HttpClientCapability"

pub handler default-http :: Http ::: JVM
  http-get url =>
    resume (http-client.request {method= "GET" url= url})
  http-post url body headers =>
    resume (http-client.request {method= "POST" url= url body= body headers= headers})
  http-put url body headers =>
    resume (http-client.request {method= "PUT" url= url body= body headers= headers})
  http-delete url =>
    resume (http-client.request {method= "DELETE" url= url})
  http-request opts =>
    resume (http-client.request opts)
