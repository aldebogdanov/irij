;; Vector build-and-fold using the Irij stdlib (Phase 3 port).
;; `std.list` is written in pure Irij on top of the bytecode emitter's
;; raw primitives — bytecode + interpreter run the same source.

use std.list :open

fn build
  (v n -> if (n == 0) v else (build (conj v n) (n - 1)))

println (sum (build #[] 500))
